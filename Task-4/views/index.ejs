<!DOCTYPE html>
<html lang ="en">
<head>
    <meta charset = "UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz Internship - Task-4</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .page {display: none;}
        .page.active {display: block;}

        .strength-bar {
            height: 6px;
            border-radius: 3px;
            transition: all 0.3s ease;
            margin-top: 6px;
        }

        .strength-text {
            font-size: 12px;
            margin-top: 4px;
            font-weight: 600;
        }

        .char-counter {
            font-size: 12px;
            color: #888;
            text-align: right;
            margin-top: 3px;
        }

        .nav-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 25px;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ccc;
            transition: all 0.3s ease;
        }

        .dot-active {
            background: #667eea;
            transform: scale(1.3);
        }

        .page-title {
            font-size: 13px;
            color: #888;
            text-align: center;
            margin-bottom: 20px;
        }

        .btn-nav {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 8px;
            padding: 10px 30px;
            color: white;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-nav:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102,126,234,0.4);
        }

        .btn-back {
            background: transparent;
            border: 2px solid #667eea;
            border-radius: 8px;
            padding: 10px 30px;
            color: #667eea;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-back:hover {
            background: #667;
            color: white;
        }

        .input-icon {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #888;
            font-size: 18px;
            user-select: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h2>User Registration</h2>
                        <p style="color:rgba(255,255,255,0.8); text-align:center; margin: 5px 0 0 0;">Cognifyz Internship Task-4</p>
                    </div>
                    <div class="card-body">
                        <div class="nav-dots">
                            <div class="dot active" id="dot1"></div>
                            <div class="dot" id="dot2"></div>
                            <div class="dot" id="dot3"></div>
                        </div>

                        <form id="regForm" action="/submit" method="POST" novalidate>
                            <div class="page active" id="page1">
                                <p class="page-title">Step 1 of 3 — Personal Info</p>

                                <div class="mb-3">
                                    <label for="name" class="form-label">Full Name</label>
                                    <input type="text" class="form-control" id="name" name="name" placeholder="Enter your full name" maxlength="50">
                                    <div class="char-counter"><span id="nameCount">0</span>/50</div>
                                    <span id="nameError" class="error-text"></span>
                                </div>

                                <div class="mb-3">
                                    <label for="email" class="form-label">Email Address</label>
                                    <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email">
                                    <span id="emailError" class="error-text"></span>
                                </div>

                                <div class="d-flex justify-content-end mt-3">
                                    <button type="button" class="btn-nav" onclick="goToPage(2)">Next →</button>
                                </div>
                        </div>

                        <div class="page" id="page2">
                            <p class="page-title">Step 2 of 3 - Your Details</p>
                            <div class="mb-3">
                                <label for="age" class="form-label">Age</label>
                                <input type="number" class="form-control" id="age" name="age" placeholder="Enter your age">
                                <span id="ageError" class="error-text"></span>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn-back" onclick="goToPage(1)">← Back</button>
                                <button type="button" class="btn-nav" onclick="goToPage(3)">Next →</button>
                            </div>
                        </div>

                        <div class="page" id="page3">
                            <p class="page-title">Step 3 of 3 — Secure Your Account</p>
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <div class="input-icon">
                                    <input type="password" class="form-control" id="password" name="password" placeholder="Minimum 6 characters">
                                    <span class="toggle-password" onclick="togglePassword()">👁</span>
                                </div>
                                <div class="strength-bar" id="strengthBar" style="width:0%; background:#ccc;"></div>
                                <div class="strength-text" id="strengthText"></div>
                                <span id="passwordError" class="error-text"></span>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <button type="button" class="btn-back" onclick="goToPage(2)">← Back</button>
                                <button type="submit" class="btn-nav">Create Account ✓</button>
                            </div>
                        </div>
                    
                    </form>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentPage = 1;

        function goToPage(pageNum) {
            if (pageNum > currentPage && !validatePage(currentPage)) return;

            document.getElementById('page' + currentPage).classList.remove('active');
            document.getElementById('dot' + currentPage).classList.remove('active');

            currentPage = pageNum;

            document.getElementById('page' + currentPage).classList.add('active');
            document.getElementById('dot' + currentPage).classList.add('active');
        }

        function validatePage(page) {
            let valid = true;

            if (page == 1) {
                document.getElementById('nameError').textContent = '';
                document.getElementById('emailError').textContent = '';

                const name = document.getElementById('name').value.trim();
                const email = document.getElementById('email').value.trim();

                if (name.length < 2) {
                    document.getElementById('nameError').textContent = 'Name must be at least 2 characters.';
                    valid = false;
                }
                 const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                 if (!emailPattern.test(email)) {
                    document.getElementById('emailError').textContent = 'Please enter a valid email address.';
                    valid = false;
                 }  
            }

            return valid;
        }

        document.getElementById('name').addEventListener('input', function() {
            document.getElementById('nameCount').textContent = this.value.length;
        });

        document.getElementById('password').addEventListener('input', function() {
            const val =this.value;
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');

            let strength = 0;
            if (val.length >= 6) strength++;
            if (val.length >= 10) strength++;
            if (/[A-Z]/.test(val)) strength++;
            if (/[0-9]/.test(val)) strength++;
            if (/[^A-Za-z0-9]/.test(val)) strength++;

            const levels = [
                { width: '0%', color: '#ccc', label: ''},
                { width: '25%', color: '#e74c3c', label: '🔴 Very Weak'},
                { width: '50%', color: '#e67e22', label: '🟠 Weak'},
                { width: '75%', color: '#f1c40f', label: '🟡 Moderate'},
                { width: '90%', color: '#2ecc71', label: '🟢 Strong'},
                { width: '100%', color: '#27ae60', label: '✅ Very Strong'},
            ];

            bar.style.width = levels[strength].width;
            bar.style.background = levels[strength].color;
            text.textContent = levels[strength].label;
            text.style.color = levels[strength].color;
        });

        function togglePassword() {
            const input = document.getElementById('password');
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        document.getElementById('regForm').addEventListener('submit', function(e) {
            const password = document.getElementById('password').value;
            document.getElementById('passwordError').textContent = '';

            if (password.length < 6) {
                document.getElementById('passwordError').textContent = 'Password must be at least 6 characters.';
                e.preventDefault();
            }
        });
    </script>
</body>
</html>